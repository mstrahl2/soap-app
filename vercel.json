{
    "headers": [
      {
        "source": "/manifest.webmanifest",
        "headers": [
          { "key": "Content-Type", "value": "application/manifest+json" }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/api/stripe-webhook",
        "destination": "/api/stripe-webhook"
      },
      {
        "source": "/(.*)",
        "destination": "/"
      }
    ]
  }
  